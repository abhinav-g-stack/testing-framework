{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Users List Response",
  "description": "JSON Schema for GET /users response from JSONPlaceholder (array of users)",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name", "username", "email"],
    "properties": {
      "id": { "type": "integer" },
      "name": { "type": "string" },
      "username": { "type": "string" },
      "email": { "type": "string" },
      "phone": { "type": "string" },
      "website": { "type": "string" }
    }
  },
  "minItems": 1
}
